# Pickle Nick — Local Development Environment
# Copy this file to .env.local and fill in your values.
#
# Frontend (Vite) — these are safe to commit (publishable keys only)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Worker secrets — set via: wrangler secret put <NAME>
# Do NOT put these in .env.local — they belong in the Worker environment only.
#
# CLERK_SECRET_KEY=sk_test_...
# RESEND_API_KEY=re_...
# OPENROUTER_API_KEY=sk-or-...
# ADMIN_EMAIL=hello@picklenick.au
#
# Optional — Facebook integration
# FB_PAGE_ID=...
# FB_PAGE_ACCESS_TOKEN=...
