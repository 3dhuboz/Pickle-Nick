# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values.
# These MUST also be added to Vercel → Project Settings → Environment Variables
# so that every device (phone, tablet, other browser) connects to the same Firestore database.
#
# Get these values from: https://console.firebase.google.com
# → Your Project → Project Settings (gear icon) → Your apps → Web app → Config

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
