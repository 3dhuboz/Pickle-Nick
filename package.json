{
  "name": "pickle-nick",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "deploy:pages": "wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute pickle-nick-db --file=worker/schema.sql",
    "db:seed": "wrangler d1 execute pickle-nick-db --file=worker/seed.sql"
  },
  "dependencies": {
    "@clerk/react": "^6.1.2",
    "lucide-react": "^0.574.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@clerk/backend": "^1.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^3.0.0"
  }
}
